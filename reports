void attendDefaulters() {
    readFile("enrollments.txt");
    cout << "\n=== ATTENDANCE DEFAULTERS (< 75%) ===" << endl;

    string rolls[300], codes[300];
    int count = 0;
    for (int i = 0; i < rowCount; i++) {
        if (fileData[i][3] == "enrolled") {
            rolls[count] = fileData[i][0];
            codes[count] = fileData[i][1];
            count++;
        }
    }

    bool found = false;
    for (int i = 0; i < count; i++) {
        double pct = getAttendancePct(rolls[i], codes[i]);
        if (pct > 0 && pct < 75.0) {
            cout << rolls[i] << " | " << codes[i] << " | " << fixed << setprecision(1) << pct << "%" << endl;
            found = true;
        }
    }
    if (!found) cout << "None found." << endl;
}

