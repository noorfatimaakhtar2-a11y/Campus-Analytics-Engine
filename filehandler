// filehandler.cpp
#include "filehandler.h"
#include <fstream>
#include <iostream>
using namespace std;

string fileData[300][8];
int rowCount = 0;

// Read file, split by comma
int readFile(string filename) {
    ifstream f(filename.c_str());
    if (!f.is_open()) return 0;

    string line;
    rowCount = 0;
    bool skip = true;

    while (getline(f, line)) {
        if (skip) { skip = false; continue; }
        if (line == "") continue;

        int col = 0;
        string cell = "";
        for (int i = 0; i < (int)line.length(); i++) {
            if (line[i] == ',') {
                fileData[rowCount][col] = cell;
                col++;
                cell = "";
            } else {
                cell = cell + line[i];
            }
        }
        fileData[rowCount][col] = cell;
        rowCount++;
    }
    f.close();
    return rowCount;
}

// Write all data to file
void writeFile(string filename, string header) {
    ofstream f(filename.c_str());
    f << header << endl;
    for (int i = 0; i < rowCount; i++) {
        for (int j = 0; j < 8; j++) {
            if (fileData[i][j] == "") break;
            f << fileData[i][j];
            if (j < 7 && fileData[i][j + 1] != "") f << ",";
        }
        f << endl;
    }
    f.close();
}

// Append one line to file
void appendFile(string filename, string line) {
    ofstream f(filename.c_str(), ios::app);
    f << line << endl;
    f.close();
}

// Search column for value, return row index or -1
int searchInColumn(int column, string value) {
    for (int i = 0; i < rowCount; i++) {
        if (fileData[i][column] == value) return i;
    }
    return -1;
}
